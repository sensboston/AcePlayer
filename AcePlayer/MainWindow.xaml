<Window x:Class="AcePlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:r="clr-namespace:AcePlayer.Rendering"
        xmlns:local="clr-namespace:AcePlayer"
        Title="AcePlayer" Height="576" Width="1024" Icon="icon.ico"
        Background="Black" WindowStartupLocation="CenterScreen"
        MouseMove="OnUserActivity">

    <Window.Resources>
        <Style x:Key="GlyphButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TextGlyphButton" TargetType="Button" BasedOn="{StaticResource GlyphButton}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="MinWidth" Value="58"/>
            <Setter Property="Padding" Value="14,0"/>
        </Style>

        <Style x:Key="DarkComboItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#FF7A00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="58"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="false" ClickMode="Press"
                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd" Background="#33FFFFFF" CornerRadius="5">
                                            <Grid Margin="9,0,7,0">
                                                <Path Data="M0,0 L7,0 L3.5,4 Z" Fill="#CCFFFFFF"
                                                      HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#4DFFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter IsHitTestVisible="False" Margin="9,0,20,0"
                                Content="{TemplateBinding SelectionBoxItem}"
                                HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border Background="#F0202020" BorderBrush="#66FFFFFF" BorderThickness="1"
                                        CornerRadius="4" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <StackPanel IsItemsHost="True" Margin="0,3"/>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Whole client is the video; all controls overlay the top and auto-hide. -->
    <Grid x:Name="VideoArea" Background="Black" MouseLeftButtonDown="OnVideoMouseDown">
        <r:VideoView x:Name="Video"/>

        <TextBlock x:Name="CenterStatus" Foreground="#CCFFFFFF" FontSize="16"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   IsHitTestVisible="False" Text="Enter a source and press Play"/>

        <TextBlock x:Name="StatsText" Foreground="#66FFFFFF" FontSize="12"
                   HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12,8"
                   IsHitTestVisible="False" Text=""/>

        <local:VolumeControl x:Name="Volume" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,10,8"/>

        <Border x:Name="TopBar" VerticalAlignment="Top" Padding="8,7">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#E6000000" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Style="{StaticResource GlyphButton}" Content="⛶"
                        ToolTip="Fullscreen (F11, double-click)" Click="OnFullscreenClick"/>
                <Button DockPanel.Dock="Right" Style="{StaticResource GlyphButton}" Content="⚙"
                        ToolTip="Register AcePlayer as the Ace Stream handler" Click="OnRegisterClick"/>
                <ComboBox DockPanel.Dock="Right" x:Name="ThresholdCombo" Style="{StaticResource DarkCombo}"
                          VerticalAlignment="Center" Margin="0,0,8,0"
                          ToolTip="Auto jump-to-live once lag exceeds this"
                          SelectionChanged="OnThresholdChanged">
                    <ComboBoxItem>Off</ComboBoxItem>
                    <ComboBoxItem>1s</ComboBoxItem>
                    <ComboBoxItem>2s</ComboBoxItem>
                    <ComboBoxItem>3s</ComboBoxItem>
                    <ComboBoxItem>4s</ComboBoxItem>
                    <ComboBoxItem>6s</ComboBoxItem>
                    <ComboBoxItem>8s</ComboBoxItem>
                </ComboBox>
                <TextBlock DockPanel.Dock="Right" Foreground="#AAFFFFFF" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,6,0" Text="auto-live"/>
                <TextBlock DockPanel.Dock="Right" x:Name="TimeText" Foreground="#EEFFFFFF" FontSize="12"
                           VerticalAlignment="Center" Margin="8,0,12,0" MinWidth="34"
                           TextAlignment="Right" Text="live"/>
                <Button DockPanel.Dock="Right" Style="{StaticResource TextGlyphButton}" Content="⟳ Live"
                        ToolTip="Jump to the live edge  ·  L" Click="OnLiveClick" Margin="0,0,4,0"/>
                <Button DockPanel.Dock="Right" x:Name="PlayButton" Style="{StaticResource TextGlyphButton}"
                        Content="▶ Play" MinWidth="70"
                        ToolTip="Play / Stop  ·  Space" Click="OnPlayClick" Margin="0,0,4,0"/>
                <Grid Margin="0,0,8,0">
                    <TextBox x:Name="SourceBox" Height="30" VerticalContentAlignment="Center"
                             FontSize="13" Padding="8,0,28,0"
                             Background="#22FFFFFF" Foreground="White" BorderThickness="0"
                             CaretBrush="White"
                             ToolTip="URL, file path, acestream content-id, acestream://… or infohash:…"
                             KeyDown="OnSourceKeyDown" TextChanged="OnSourceTextChanged"/>
                    <Button x:Name="ClearButton" Content="✕" Width="24" Height="22"
                            HorizontalAlignment="Right" Margin="0,0,4,0"
                            Style="{StaticResource GlyphButton}" FontSize="12"
                            ToolTip="Clear" Click="OnClearSource" Visibility="Collapsed"/>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</Window>
