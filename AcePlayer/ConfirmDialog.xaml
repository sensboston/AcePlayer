<Window x:Class="AcePlayer.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        MouseLeftButtonDown="OnDrag" KeyDown="OnKey">
    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="Background" Value="#3AFFFFFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6" Padding="14,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="#FF7A00"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6" Padding="14,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#FF9430"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#232323" BorderBrush="#55FFFFFF" BorderThickness="1"
            CornerRadius="10" Padding="24" MaxWidth="480">
        <StackPanel>
            <TextBlock x:Name="TitleText" Foreground="White" FontSize="17" FontWeight="SemiBold"
                       Margin="0,0,0,12"/>
            <TextBlock x:Name="MessageText" Foreground="#D0D0D0" FontSize="13" TextWrapping="Wrap"
                       Margin="0,0,0,22" LineHeight="19"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelBtn" Content="Cancel" Style="{StaticResource DialogButton}" Click="OnCancel"/>
                <Button x:Name="OkBtn" Content="Register" Style="{StaticResource AccentButton}" Click="OnOk"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
